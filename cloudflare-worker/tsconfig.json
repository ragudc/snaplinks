{
  "compilerOptions": {
    "target":           "ES2022",
    "lib":              ["ES2022"],
    "module":           "ES2022",
    "moduleResolution": "Bundler",
    "strict":           true,
    "skipLibCheck":     true,
    "noUnusedLocals":   true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "types":            ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", ".wrangler"]
}
