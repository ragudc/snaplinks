# ─── Supabase — PUBLIC ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Supabase — PRIVATE (server-side only) ───────────────────────
SUPABASE_SERVICE_ROLE_KEY=

# ─── App URLs ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
# ─── Cloudflare Worker (set after deploying the Worker) ──────────
# The public URL of the Cloudflare Worker that handles redirections
# Local dev: http://localhost:3000 (Next.js handles redirects)
# Production: https://snaplinks-worker.YOUR_SUBDOMAIN.workers.dev
NEXT_PUBLIC_SHORT_URL_BASE=

# ─── PayPal ───────────────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_PLAN_ID_PLUS=
NEXT_PUBLIC_PAYPAL_PLAN_ID_PRO=
PAYPAL_PLAN_ID_PLUS=
PAYPAL_PLAN_ID_PRO=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
