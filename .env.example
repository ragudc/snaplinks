# ─────────────────────────────────────────────────────────────────────────────
# SnapLinks — Environment Variables
# Copy this file to .env.local and fill in the values.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local — it contains real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your Supabase project URL (safe to expose — used on client + server)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose — RLS policies enforce security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — NEVER use with NEXT_PUBLIC_ prefix
# Used only in API Routes to bypass RLS for admin operations
SUPABASE_SERVICE_ROLE_KEY=

# ─── App URLs ────────────────────────────────────────────────────────────────

# Full URL of the deployed Next.js app (no trailing slash)
# Local:      http://localhost:3000
# Production: https://snaplinks.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Base URL used to build short links (the Cloudflare Worker URL)
# Local:      http://localhost:8787
# Production: https://snaplinks-worker.YOUR_SUBDOMAIN.workers.dev
NEXT_PUBLIC_SHORT_URL_BASE=http://localhost:8787

# ─── PayPal ──────────────────────────────────────────────────────────────────
# Found in: PayPal Developer Dashboard → My Apps & Credentials

# PayPal client ID (safe to expose — used in the PayPal JS SDK on client)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# PayPal client secret — NEVER expose client-side
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# "sandbox" for testing, "live" for production
PAYPAL_MODE=sandbox

# PayPal Billing Plan IDs — created via PayPal API or Dashboard
# These identify the recurring subscription plans for Plus and Pro tiers
NEXT_PUBLIC_PAYPAL_PLAN_ID_PLUS=
NEXT_PUBLIC_PAYPAL_PLAN_ID_PRO=
PAYPAL_PLAN_ID_PLUS=
PAYPAL_PLAN_ID_PRO=

# PayPal Webhook ID — found in PayPal Dashboard → Webhooks
# Used to verify incoming webhook signatures for subscription events
PAYPAL_WEBHOOK_ID=
